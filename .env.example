# ── CrossScout indexer configuration ───────────────────────────────
# One indexer instance runs per rollup. HOST_CHAIN_ID is the rollup this
# instance lives inside; it only surfaces XTs that chain participates in.
# Ready-made presets: .env.localnet (local-testnet), .env.stage.

HOST_CHAIN_ID=77777
L1_CHAIN_ID=560048

# ── storage ────────────────────────────────────────────────────────
DATABASE_URL=postgres://crossscout:crossscout@localhost:5432/crossscout
REDIS_URL=redis://localhost:6379
CLICKHOUSE_URL=http://localhost:8123

# ── data sources ───────────────────────────────────────────────────
# Per-rollup execution RPCs (host first, then counterparties), as
# comma-separated chain_id=url pairs. Mailbox + bridge logs are polled on
# every listed chain so both legs of a session are observed.
EL_RPC_URLS=77777=http://localhost:18545,88888=http://localhost:28545
# Per-rollup op-rbuilder flashblocks websockets (~200ms pre-confirmations).
# Optional: leave empty where no builder socket is exposed.
FLASHBLOCKS_WS_URLS=77777=ws://localhost:17111,88888=ws://localhost:27111
# L1 settlement RPC (superblock dispute games + anchor registry).
L1_RPC_URL=http://localhost:8546

# ── on-chain addresses ─────────────────────────────────────────────
# UniversalBridgeMailbox (same address on every rollup).
MAILBOX_ADDRESS=0x0000000000000000000000000000000000000000
# ComposeL2ToL2Bridge (+ any additional authorized bridges), comma-separated.
BRIDGE_ADDRESSES=0x0000000000000000000000000000000000000000
# L1 DisputeGameFactory the publisher settles superblocks through.
DISPUTE_GAME_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
# L1 ComposeAnchorStateRegistry; unset disables finalization tracking.
ANCHOR_STATE_REGISTRY_ADDRESS=
# Compose dispute game type (publisher's COMPOSE_GAME_TYPE).
COMPOSE_GAME_TYPE=5555

# ── ingestion ──────────────────────────────────────────────────────
# Block to start ingestion from; `latest` (or empty) starts at the head.
EL_START_BLOCK=latest
L1_START_BLOCK=latest
# Poll interval for RPC log sources, ms.
POLL_INTERVAL_MS=1000
# Max blocks per eth_getLogs call (public RPCs cap the span).
LOG_MAX_RANGE=5000
# Seconds before an XT without a sealed inclusion is rolled back
# (a pre-confirmation that never seals is an aborted 2PC instance).
STALL_TIMEOUT_SECONDS=3840

# ── api ────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
# Public explorer URL advertised by `GET /` (optional).
EXPLORER_URL=

# ── explorer ───────────────────────────────────────────────────────
# Api base URL the explorer talks to.
VITE_API_URL=http://localhost:3001
# Rollup display names, comma-separated <chain_id>=<name> pairs.
VITE_CHAIN_NAMES=
# Network landing page linked from the overview header (optional).
VITE_NETWORK_SITE_URL=

RUST_LOG=info,cross_scout=debug
