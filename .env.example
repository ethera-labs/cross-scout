# ── CrossScout indexer configuration ───────────────────────────────
# One indexer instance runs per rollup. HOST_CHAIN_ID is the rollup this
# instance lives inside; it only surfaces XTs that chain participates in.

HOST_CHAIN_ID=8453

# ── storage ────────────────────────────────────────────────────────
DATABASE_URL=postgres://crossscout:crossscout@localhost:5432/crossscout
REDIS_URL=redis://localhost:6379
CLICKHOUSE_URL=http://localhost:8123

# ── data sources (per host rollup) ─────────────────────────────────
# op-reth execution-layer RPC (mailbox logs, receipts, roots)
EL_RPC_URL=http://localhost:8545
# op-rbuilder flashblocks websocket (≈200ms pre-confirmations)
FLASHBLOCKS_WS_URL=ws://localhost:1111
# Shared Publisher SBCP event stream (2PC votes / decisions)
SBCP_WS_URL=ws://localhost:2222
# L1 settlement RPC (superblock proposal / validation / finalization)
L1_RPC_URL=http://localhost:8546

# ── on-chain addresses on the host rollup ──────────────────────────
MAILBOX_ADDRESS=0x0000000000000000000000000000000000000000
SBCP_COORDINATOR_ADDRESS=0x0000000000000000000000000000000000000000
# L1
SETTLEMENT_ADDRESS=0x0000000000000000000000000000000000000000

# ── ingestion ──────────────────────────────────────────────────────
# start ingestion from this EL block (0 = genesis)
EL_START_BLOCK=0
# poll interval for RPC log sources, ms
POLL_INTERVAL_MS=1000
# SBCP period length in seconds (watchdog uses this to flag stalled XTs)
PERIOD_SECONDS=3840

# Run with synthetic in-memory sources instead of live chains.
# Lets the full pipeline (ingest → correlate → store → api) run against
# only Postgres + Redis, no rollup infra required.
USE_MOCK_SOURCES=true

# ── api ────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0

RUST_LOG=info,cross_scout=debug
